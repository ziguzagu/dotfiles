#!/bin/zsh
# Claude Code status line
# Renders cwd + git status + model name, styled after my zsh prompt.
#
# Setup: referenced from ~/.claude/settings.json statusLine (see `make claude`)
set -eu -o pipefail

input=$(cat)
dir=$(echo "$input" | jq -r '.workspace.current_dir')
model=$(echo "$input" | jq -r '.model.display_name')
e=$(printf '\033')

cd "$dir" 2>/dev/null || true

gitinfo=""
if git rev-parse --git-dir >/dev/null 2>&1; then
  branch=$(git --no-optional-locks branch --show-current 2>/dev/null || true)
  if [ -z "$branch" ]; then
    branch=$(git --no-optional-locks rev-parse --short HEAD 2>/dev/null || echo '?')
  fi

  ab=""
  upstream=$(git --no-optional-locks rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
  if [ -n "$upstream" ]; then
    ahead=$(git --no-optional-locks rev-list "$upstream"..HEAD --count 2>/dev/null || echo 0)
    behind=$(git --no-optional-locks rev-list HEAD.."$upstream" --count 2>/dev/null || echo 0)
    if [ "$ahead" -gt 0 ]; then ab="$ab+$ahead"; fi
    if [ "$behind" -gt 0 ]; then ab="$ab-$behind"; fi
  fi

  dirty=""
  if ! git --no-optional-locks diff --quiet 2>/dev/null || ! git --no-optional-locks diff --cached --quiet 2>/dev/null; then
    dirty=" ${e}[38;5;160m${e}[1m✖︎${e}[0m"
  fi

  gitinfo=" ${e}[38;5;117m(${branch}${ab})${e}[0m${dirty}"
fi

base=$(basename "$dir")
printf '%s\n' "${e}[2m${e}[38;5;214m${base}${e}[0m${gitinfo} ${e}[2m[${model}]${e}[0m"
