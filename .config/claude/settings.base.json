{
  "statusLine": {
    "type": "command",
    "command": "claude-statusline"
  },
  "permissions": {
    "allow": [
      "Bash(docker compose ps *)",
      "Bash(gh issue view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(git fetch *)",
      "Bash(rg *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify"
          }
        ]
      }
    ]
  }
}
